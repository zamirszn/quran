{
  "name": "Flutter Dev Environment",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.dart-code",
        "Dart-Code.flutter"
      ]
    }
  },
  "remoteUser": "root",
  "workspaceFolder": "/workspace",
  "runArgs": [
    "--network=host",
    "-v", "${env:HOME}/.android:/root/.android"
  ],
  "mounts": [
    "source=flutter-cache,target=/opt/flutter,type=volume",
    "source=android-cache,target=/opt/android-sdk,type=volume"
  ]
}
