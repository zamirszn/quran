{
  "name": "Flutter Dev Environment",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.dart-code",
        "Dart-Code.flutter"
      ]
    }
  },
  "remoteUser": "root",
  "runArgs": [
  "--network=host",
  "-v", "${env:HOME}/.android:/root/.android"
]
}
